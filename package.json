{
  "name": "gitatlas",
  "version": "0.2.0",
  "description": "The code graph that lives in your git history - built once, correct at every commit, served to every AI coding tool via MCP.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bajpayeeritik/gitatlas.git"
  },
  "type": "module",
  "bin": {
    "gitatlas": "dist/cli.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "code-graph",
    "mcp",
    "tree-sitter",
    "ai",
    "context",
    "knowledge-graph",
    "static-analysis"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^12.11.1",
    "commander": "^12.1.0",
    "tree-sitter-wasms": "^0.1.12",
    "web-tree-sitter": "^0.24.7",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}
